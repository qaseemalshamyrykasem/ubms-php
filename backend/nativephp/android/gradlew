#!/bin/sh
# Gradle wrapper script - downloaded by NativePHP install
# In CI, this is regenerated by `gradle wrapper`.

DIR="$(cd "$(dirname "$0")" && pwd)"
APP_HOME="$DIR"

# Use Java 17 if available
if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

# Initialize wrapper (placeholder - real wrapper generated by NativePHP install)
exec "$JAVACMD" -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
