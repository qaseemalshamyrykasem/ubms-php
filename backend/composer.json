{
    "name": "ubms/university-batch-management-system",
    "type": "project",
    "description": "University Batch Management System - Laravel 12 Backend",
    "keywords": ["laravel", "university", "attendance", "telegram", "management"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-xml": "*",
        "ext-curl": "*",
        "ext-zip": "*",
        "ext-gd": "*",
        "ext-intl": "*",
        "ext-bcmath": "*",
        "ext-json": "*",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10",
        "simplesoftwareio/simple-qrcode": "^2.0",
        "maatwebsite/excel": "^3.1.62",
        "barryvdh/laravel-dompdf": "^3.0",
        "spatie/laravel-permission": "^6.4",
        "livewire/livewire": "^3.5",
        "nativephp/electron": "^0.6.0",
        "nativephp/laravel": "^0.6.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --tag=lang-public --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
